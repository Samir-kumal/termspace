{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "termspace",
  "version": "0.1.0",
  "identifier": "com.termspace.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "termspace v0.1.0",
        "width": 800,
        "height": 600,
        "transparent": true,
        "backgroundColor": "#1a1612ff"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Samir-kumal/termspace/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwN0FGQTQ5NkQ2MTBEMzQKUldRMERXRnRTZnA2UUhpK2RadVpjVjB3b0F4UmV6MHRtVzJMMWNUU3BrckEvSXhHMmVGTVhEcFkK"
    }
  }
}
